<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiMarkdownRendererWithLaTeX.MainPage"
             xmlns:local="clr-namespace:MauiMarkdownRendererWithLaTeX"
             Shell.NavBarIsVisible="False">

    <Grid ColumnDefinitions="2*,*" Padding="15" ColumnSpacing="15">

        <ScrollView Grid.Column="0">
            <local:MarkdownRenderer x:Name="mdr" 
                                    BackgroundColor="#E9E9E9" 
                                    BaseFontSize="15" 
                                    LatexFontSize="12"
                                    WarmUp="True"
                                    Padding="10,10,10,10"/>
        </ScrollView>

        <Grid Grid.Column="1" RowDefinitions="*, Auto" RowSpacing="15">

            <Editor x:Name="mdEditor" Grid.Row="0" 
                    Placeholder="Enter Markdown here..."
                    VerticalTextAlignment="Start"
                    VerticalOptions="Fill"
                    HorizontalOptions="Fill"
                    AutoSize="TextChanges"/>

            <VerticalStackLayout Grid.Row="1" Spacing="12">

                <Label Text="Rendering Engine" FontAttributes="Bold" FontSize="16"/>
                <BoxView HeightRequest="1" Color="LightGray"/>

                    <Grid ColumnDefinitions="*, Auto, Auto ,60" ColumnSpacing="10">
                        <Label Text="Incremental" VerticalOptions="Center"/>
                        <Switch x:Name="incrementalSwitch" Grid.Column="1"/>
                        <Label Text="Chunk Size" Grid.Column="2" VerticalOptions="Center"></Label>
                        <Entry x:Name="chunkSizeEntry" Grid.Column="3" 
                            Text="5" Keyboard="Numeric" 
                            Placeholder="Chars" HorizontalTextAlignment="Center"/>
                    </Grid>

                    <Label Text="Dynamic Styles (Live)" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0"/>
                <BoxView HeightRequest="1" Color="LightGray"/>

                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto" ColumnSpacing="10">
                    <Label Text="Base Size" VerticalOptions="Center"/>
                    <Slider Grid.Column="1" Minimum="10" Maximum="30" Value="15"
                        ValueChanged="OnBaseFontSizeChanged"/>

                    <Label Grid.Row="1" Text="Latex Size" VerticalOptions="Center"/>
                    <Slider Grid.Row="1" Grid.Column="1" Minimum="8" Maximum="25" Value="12"
                        ValueChanged="OnLatexFontSizeChanged"/>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Text Color" FontSize="12"/>
                        <Entry x:Name="textColorEntry" Text="#000000" Unfocused="OnColorUnfocused"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Latex Color" FontSize="12"/>
                        <Entry x:Name="latexColorEntry" Text="#2D5A27" Unfocused="OnColorUnfocused"/>
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="Auto,60,*" ColumnSpacing="10">
                    <Label Text="Append Throttle (ms)" Grid.Column="0" VerticalOptions="Center"></Label>
                    <Entry Text="50" Unfocused="OnThrottleUnfocused" Grid.Column="1" VerticalOptions="Center"></Entry>
                    
                    <Button x:Name="btnSubmit" Text="RENDER MARKDOWN" 
                    Clicked="OnSubmitButtonClicked" 
                    HeightRequest="50" CornerRadius="8" Margin="0,10,0,0" Grid.Column="2" VerticalOptions="Center"/>
                </Grid>
                

            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
